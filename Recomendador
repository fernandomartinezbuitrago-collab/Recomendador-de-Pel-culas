# --- PASO 1 Y 2: CARGA Y PREPARACIÓN ---
print(">>> CARGANDO DATOS...")
# 1. Cargar
ratings = cargar_datos("/kaggle/input/movielens/ratings.csv") 
movies = cargar_datos("/kaggle/input/movielens/movies.csv")

# 2. Ingeniería de Características (Extraer Año)
# Usamos tu herramienta del Sandbox para limpiar el título
print(">>> PROCESANDO TÍTULOS...")
movies = extraer_texto_regex(movies, 'title', r'\((\d{4})\)', 'year')

# --- PASO 3: FUSIÓN Y AUDITORÍA ---
print(">>> CREANDO DATASET MAESTRO...")
# Unimos las tablas
df_completo = pd.merge(ratings, movies, on='movieId', how='inner')

# Ahora sí, la auditoría funcionará porque df_completo ya existe
auditoria_rapida(df_completo)





# --- PASO 5: ANÁLISIS DE DISTRIBUCIÓN DE VOTOS ---
print(">>> 5. ¿CÓMO VOTA LA GENTE? (Psicología del Usuario)")
# Usamos tu herramienta gráfica del Sandbox
grafico_distribucion(df_completo, 'rating')

# Interpretación rápida con Pandas
promedio = df_completo['rating'].mean()
print(f"Nota media global: {promedio:.2f} / 5.0")


# --- PASO 6: EL PROBLEMA DE LA "COLA LARGA" (Long Tail) ---
# Agrupamos por título para ver cuántos votos tiene cada peli
# ESTO ES PANDAS PURO: .groupby() es la herramienta más potente para resumir.
movie_stats = df_completo.groupby('title').agg({'rating': ['count', 'mean']})

# Aplanamos las columnas para que sea fácil de leer
movie_stats.columns = ['num_votos', 'nota_promedio']

print("\n>>> 6. TOP PELÍCULAS MÁS POPULARES (Por volumen):")
display(movie_stats.sort_values(by='num_votos', ascending=False).head(10))

# Visualizar la "Cola Larga"
plt.figure(figsize=(10,6))
sns.histplot(movie_stats['num_votos'], bins=50, kde=False)
plt.title("Distribución de Votos por Película (La mayoría tiene pocos votos)")
plt.xlabel("Número de votos")
plt.xlim(0, 200) # Hacemos zoom en las pelis con pocos votos
plt.show()





# --- PASO 7: FILTRADO DE DATOS (DATA PREPARATION) ---
print(">>> 7. LIMPIANDO EL RUIDO (Películas con pocos votos)...")

# Definimos el umbral: Solo queremos películas "consolidadas"
umbral_votos = 50

# Identificamos los títulos que cumplen la condición
# (Usamos la tabla 'movie_stats' que creamos en el paso anterior)
peliculas_populares = movie_stats[movie_stats['num_votos'] >= umbral_votos].index

# Filtramos el dataset original
# "Quédate solo con las filas cuyo título esté en la lista de populares"
df_final = df_completo[df_completo['title'].isin(peliculas_populares)]

print(f"Registros originales: {df_completo.shape[0]}")
print(f"Registros tras filtrado: {df_final.shape[0]}")
print(f"Hemos eliminado {df_completo.shape[0] - df_final.shape[0]} valoraciones de películas oscuras.")


# --- PASO 8: CREACIÓN DE LA MATRIZ DE UTILIDAD ---
print("\n>>> 8. TRANSFORMANDO A MATRIZ PARA LA IA...")

# Usamos tu herramienta NUEVA del Sandbox v1.6
matriz_peliculas = crear_matriz_utilidad(
    df=df_final, 
    index_col='userId',   # Filas = Usuarios
    columns_col='title',  # Columnas = Películas
    values_col='rating'   # Valor = Nota
)

# Vistazo a la matriz
display(matriz_peliculas.head())





from scipy.sparse import csr_matrix
from sklearn.neighbors import NearestNeighbors

# --- RECUPERACIÓN: PASOS 9 y 10 (Preparar y Entrenar) ---
print(">>> RE-GENERANDO MODELO...")

# 1. Transponer la matriz (Filas = Películas) -> AQUÍ SE DEFINE LA VARIABLE QUE FALTABA
matriz_modelo = matriz_peliculas.T 

# 2. Comprimir datos
matriz_sparse = csr_matrix(matriz_modelo.values)

# 3. Entrenar IA
modelo_knn = NearestNeighbors(metric='cosine', algorithm='brute')
modelo_knn.fit(matriz_sparse)
print("✅ Modelo entrenado y variable 'matriz_modelo' lista.")


# --- PASO 11: FUNCIÓN DE RECOMENDACIÓN ---
def recomendar_peliculas(nombre_pelicula, n_recomendaciones=5):
    # Buscar título
    coincidencias = matriz_modelo.index[matriz_modelo.index.str.contains(nombre_pelicula, case=False, regex=False)]
    
    if len(coincidencias) == 0:
        print(f"❌ No encontré '{nombre_pelicula}' (o tiene menos de 50 votos).")
        return
    
    titulo_exacto = coincidencias[0]
    print(f"🎬 Película base: {titulo_exacto}")
    
    # Preguntar al Modelo
    indice_fila = matriz_modelo.index.get_loc(titulo_exacto)
    vector_pelicula = matriz_modelo.iloc[indice_fila, :].values.reshape(1, -1)
    distancias, indices = modelo_knn.kneighbors(vector_pelicula, n_neighbors=n_recomendaciones+1)
    
    # Mostrar resultados
    print("\n💡 SI TE GUSTÓ ESA, MIRA ESTAS:")
    for i in range(1, len(distancias.flatten())):
        vecina = matriz_modelo.index[indices.flatten()[i]]
        distancia = distancias.flatten()[i]
        print(f"{i}. {vecina} (Similitud: {1-distancia:.2%})")

# --- PRUEBA DE FUEGO ---
recomendar_peliculas('Matrix')





from sklearn.metrics.pairwise import cosine_similarity

# --- PASO 1: PREPARACIÓN DE DATOS (Ingeniería de Géneros) ---
print(">>> 1. ANALIZANDO EL ADN DE LAS PELÍCULAS (GÉNEROS)...")

# Recargamos movies para asegurarnos de tener todos los títulos (incluso los que filtramos antes)
# Ojo: Si quieres usar solo las >50 votos, usa 'df_final' en lugar de 'movies'
movies_content = movies.copy()

# Las pelis vienen como "Action|Adventure|Sci-Fi". Vamos a separarlas.
# Esta función mágica convierte los textos en una tabla de 1 y 0
matriz_generos = movies_content['genres'].str.get_dummies(sep='|')

print(f"✅ Matriz de Contenido creada.")
print(f"   - Tenemos {matriz_generos.shape[0]} películas.")
print(f"   - Hemos detectado {matriz_generos.shape[1]} géneros distintos.")
display(matriz_generos.head(3))


# --- PASO 2: CALCULAR SIMILITUD (Matemáticas) ---
print("\n>>> 2. CALCULANDO PARECIDOS MATEMÁTICOS...")

# Calculamos la similitud del Coseno entre los géneros de todas las películas
# Esto crea una tabla gigante de "Peli vs Peli" basada solo en su temática
similitud_generos = cosine_similarity(matriz_generos)

print("✅ Mapa de similitudes calculado.")


# --- PASO 3: EL MOTOR DE RECOMENDACIÓN (La Función) ---
def recomendar_por_contenido(titulo_pelicula, n_recomendaciones=5):
    # 1. Buscar la película (igual que antes)
    # Usamos try/except por si el título no existe
    try:
        # Buscamos el índice (la fila) donde está esa peli
        idx = movies_content[movies_content['title'].str.contains(titulo_pelicula, case=False)].index[0]
        titulo_real = movies_content.loc[idx, 'title']
        generos_real = movies_content.loc[idx, 'genres']
        
        print(f"🎬 Película base: {titulo_real}")
        print(f"   (Géneros: {generos_real})")
        print("\n💡 PORQUE TE GUSTA EL GÉNERO, TE RECOMIENDO:")
        
    except IndexError:
        print(f"❌ No encontré ninguna película llamada '{titulo_pelicula}'.")
        return

    # 2. Buscar las más parecidas en nuestra matriz de similitud
    # Obtenemos las puntuaciones de todas las pelis contra la nuestra
    scores = list(enumerate(similitud_generos[idx]))
    
    # 3. Las ordenamos de mayor a menor similitud
    scores_ordenados = sorted(scores, key=lambda x: x[1], reverse=True)
    
    # 4. Imprimimos las Top N (saltamos la 0 porque es ella misma)
    for i in range(1, n_recomendaciones + 1):
        indice_vecina = scores_ordenados[i][0]
        score = scores_ordenados[i][1]
        
        titulo_vecina = movies_content.loc[indice_vecina, 'title']
        genero_vecina = movies_content.loc[indice_vecina, 'genres']
        
        # Solo mostramos si tiene algo de sentido (similitud > 0)
        if score > 0:
            print(f"{i}. {titulo_vecina}")
            print(f"   -> Similitud: {score:.2%} ({genero_vecina})")

# --- PRUEBA DE FUEGO ---
# Probamos con la misma peli que en el KNN para comparar resultados
recomendar_por_contenido('Matrix')
