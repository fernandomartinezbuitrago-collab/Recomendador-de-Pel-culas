def mapa_correlacion(df):
    """Mapa de calor inteligente."""
    plt.figure(figsize=(12, 8))
    df_temp = df.copy()
    columnas_texto = df_temp.select_dtypes(exclude=[np.number]).columns
    for col in columnas_texto:
        df_temp[col] = df_temp[col].astype('category').cat.codes
    
    corr = df_temp.corr()
    sns.heatmap(corr, annot=True, cmap='coolwarm', fmt=".2f")
    plt.title("Mapa de Correlación (Todo incluido)")
    plt.show()

def grafico_distribucion(df, columna):
    """Histograma simple."""
    plt.figure(figsize=(8, 5))
    sns.histplot(data=df, x=columna, kde=True)
    plt.title(f"Distribución de: {columna}")
    plt.show()

def grafico_categorias(df, columna, objetivo=None):
    """Barras de conteo."""
    plt.figure(figsize=(8, 5))
    if objetivo:
        sns.countplot(data=df, x=columna, hue=objetivo)
        plt.title(f"{columna} vs {objetivo}")
    else:
        sns.countplot(data=df, x=columna)
        plt.title(f"Conteo de: {columna}")
    plt.show()

def grafico_caja(df, columna_num, columna_cat):
    """Boxplot para outliers."""
    plt.figure(figsize=(8, 5))
    sns.boxplot(data=df, x=columna_cat, y=columna_num)
    plt.title(f"Boxplot: {columna_num} por {columna_cat}")
    plt.show()

def grafico_densidad_comparativa(df, variable, categoria):
    """Densidad superpuesta."""
    plt.figure(figsize=(10, 6))
    sns.kdeplot(data=df, x=variable, hue=categoria, fill=True)
    plt.title(f"Densidad de {variable} por {categoria}")
    plt.show()

def grafico_paneles(df, variable, categoria):
    """Gráficos separados por columnas."""
    sns.displot(data=df, x=variable, col=categoria, kde=True, height=4, aspect=1.2)
    print(f"✅ Paneles generados para {variable} separados por {categoria}")

