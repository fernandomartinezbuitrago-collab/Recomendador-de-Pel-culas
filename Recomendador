def cargar_datos(ruta):
    """Carga CSV o Excel detectando el formato automáticamente."""
    try:
        if ruta.endswith('.csv'):
            df = pd.read_csv(ruta)
        elif ruta.endswith('.xlsx'):
            df = pd.read_excel(ruta)
        else:
            print("❌ Formato no soportado. Usa CSV o Excel.")
            return None
            
        print(f"✅ Datos cargados con éxito: {df.shape[0]} filas, {df.shape[1]} columnas.")
        return df
    except FileNotFoundError:
        print("❌ Error: El archivo no existe.")
        return None

def auditoria_rapida(df):
    """Informe ejecutivo de los datos."""
    print("\n--- 1. VISTA PREVIA (Head) ---")
    display(df.head(3))
    
    print("\n--- 2. INFORMACIÓN TÉCNICA ---")
    print(df.info())
    
    print("\n--- 3. VALORES NULOS (Missing) ---")
    nulos = df.isnull().sum()
    print(nulos[nulos > 0])
    
    print("\n--- 4. DUPLICADOS ---")
    print(f"Filas duplicadas: {df.duplicated().sum()}")

def limpiar_basico(df):
    """Quita duplicados y rellena nulos numéricos con la mediana."""
    df_clean = df.copy()
    df_clean = df_clean.drop_duplicates()
    
    cols_numericas = df_clean.select_dtypes(include=[np.number]).columns
    for col in cols_numericas:
        df_clean[col] = df_clean[col].fillna(df_clean[col].median())
        
    print("✅ Limpieza básica terminada (Nulos numéricos rellenados).")
    return df_clean

def preparar_para_ia(df, columna_objetivo, columnas_a_borrar):
    """
    1. Elimina columnas inútiles.
    2. Convierte texto a números (One-Hot Encoding).
    3. Separa X (Datos) e y (Objetivo).
    """
    # Borrar basura
    df_ml = df.drop(columnas_a_borrar, axis=1)
    
    # Convertir todo el texto a números (Dummies)
    df_ml = pd.get_dummies(df_ml, drop_first=True)
    
    # Separar X e y
    X = df_ml.drop(columna_objetivo, axis=1)
    y = df_ml[columna_objetivo]
    
    print(f"✅ Datos listos para IA.")
    print(f"   - X (Variables): {X.shape}")
    print(f"   - y (Objetivo): {y.shape}")
    return X, y

