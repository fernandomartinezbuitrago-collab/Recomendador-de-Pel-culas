# 3. HERRAMIENTAS DE INGENIERÍA DE CARACTERÍSTICAS
# ------------------------------------------------------------------------------

def crear_columna_suma(df, lista_columnas, nombre_nueva_columna):
    """Crea una columna que es la suma de otras."""
    df[nombre_nueva_columna] = df[lista_columnas].sum(axis=1)
    print(f"✅ Columna '{nombre_nueva_columna}' creada sumando: {lista_columnas}")
    return df

def extraer_texto_regex(df, columna_origen, patron, nombre_nueva_columna):
    """Extrae texto usando expresiones regulares (Regex)."""
    df[nombre_nueva_columna] = df[columna_origen].str.extract(patron, expand=False)
    print(f"✅ Texto extraído de '{columna_origen}' a '{nombre_nueva_columna}'.")
    return df

def agrupar_categorias(df, columna, diccionario_reemplazo):
    """Reemplaza valores en una columna usando un diccionario."""
    df[columna] = df[columna].replace(diccionario_reemplazo)
    print(f"✅ Valores reemplazados en '{columna}'.")
    return df

def crear_matriz_utilidad(df, index_col, columns_col, values_col, fill_value=0):
    """
    Convierte datos transaccionales en Matrix (Usuario vs Item).
    Vital para Recomendadores Colaborativos.
    """
    print(f"🔄 Transformando tabla a Matriz: {index_col} vs {columns_col}...")
    matrix = df.pivot_table(index=index_col, columns=columns_col, values=values_col)
    
    # Rellenar huecos
    matrix = matrix.fillna(fill_value)
    
    print(f"✅ Matriz creada. Dimensiones: {matrix.shape}")
    print(f"   - Sparsity (Huecos): {1.0 - (np.count_nonzero(matrix) / float(matrix.size)):.2%}")
    return matrix

